# frozen_string_literal: true

source 'https://rubygems.org'

gem 'pg', '~> 1.1'
gem 'pg_search'

gem 'puma', '>= 5.0'
gem 'rails', '~> 8.1.2'

# Auth
gem 'bcrypt', '~> 3.1.7'
gem 'jwt'

# CORS
gem 'rack-cors'

# Background jobs
gem 'sidekiq'

# Request throttling (per-endpoint rate limits)
gem 'rack-attack'

# Image processing (ActiveStorage)
gem 'image_processing', '~> 1.2'

# HTTP client (for Perenual API)
gem 'faraday'

# Required by ActiveSupport::Cache::RedisCacheStore — Sidekiq's redis-client
# alone isn't enough. Backs Rails.cache with our existing Redis service.
gem 'redis'

# Performance
gem 'bootsnap', require: false

gem 'tzinfo-data', platforms: [:windows, :jruby]

gem 'brakeman', require: false
gem 'bundler-audit', require: false

group :development, :test do
  gem 'debug', platforms: [:mri, :windows], require: 'debug/prelude'
  gem 'faker'
  gem 'rubocop-rails', require: false
end

group :development do
  gem 'annotaterb'
  # Browsable /letter_opener route for inspecting outbound email in dev.
  gem 'letter_opener_web'
end
